<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:pomodero.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="650"
        Width="450" Height="650"
        x:Class="pomodero.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Pomodoro Timer"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
        <!-- Background Image -->
        <Image Source="/Assets/Behelit.jpeg" 
               Stretch="UniformToFill" 
               Opacity="0.4"/>
        
        <!-- Subtle Overlay for Readability -->
        <Rectangle Fill="{DynamicResource SystemControlBackgroundAltHighBrush}" 
                   Opacity="0.5"/>

        <TabControl Margin="10">
            <!-- Timer Tab -->
            <TabItem Header="Timer" FontSize="16">
            <ScrollViewer>
                <StackPanel Margin="20" Spacing="25">
                    <!-- Timer Display with Progress Ring -->
                    <StackPanel Spacing="15">
                        <TextBlock Text="{Binding StatusText}" 
                                   FontSize="24" 
                                   HorizontalAlignment="Center"
                                   FontWeight="Bold"
                                   Foreground="{Binding StatusColor}"/>
                        
                        <Panel Width="220" Height="220" HorizontalAlignment="Center">
                            <!-- Background Circle -->
                            <Ellipse Stroke="{Binding StatusColor}" 
                                     StrokeThickness="4" 
                                     Opacity="0.2"/>
                            
                            <!-- Progress Ring -->
                            <Arc Stroke="{Binding StatusColor}" 
                                 StrokeThickness="8" 
                                 StrokeJoin="Round"
                                 StrokeLineCap="Round"
                                 StartAngle="-90"
                                 SweepAngle="{Binding ProgressSweepAngle}"
                                 Width="220" Height="220"/>
                            
                            <TextBlock Text="{Binding TimeString}" 
                                       FontSize="64" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       FontWeight="ExtraBold"
                                       Foreground="{Binding StatusColor}"/>
                        </Panel>

                        <!-- Session Dots (Daily Progress Grouped by 4) -->
                        <ItemsControl HorizontalAlignment="Center">
                            <ItemsControl.ItemsSource>
                                <MultiBinding Converter="{x:Static vm:SessionGroupsConverter.Instance}">
                                    <Binding Path="SessionsCompletedToday"/>
                                    <Binding Path="TargetSessions"/>
                                </MultiBinding>
                            </ItemsControl.ItemsSource>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" MaxWidth="350" HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding}" Margin="10,5">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Ellipse Width="14" Height="14" Fill="{Binding}"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Controls -->
                    <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
                        <Button Content="{Binding StartStopButtonText}" 
                                Command="{Binding StartStopCommand}"
                                Width="130" Height="50"
                                FontSize="20"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Classes="accent"/>
                        
                        <Button Content="Reset" 
                                Command="{Binding ResetCommand}"
                                Width="130" Height="50"
                                FontSize="20"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- Settings Tab -->
        <TabItem Header="Settings" FontSize="16">
            <ScrollViewer>
                <StackPanel Margin="20" Spacing="25">
                    <!-- Theme Toggle -->
                    <DockPanel>
                        <TextBlock Text="Appearance" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold"/>
                        <Button Command="{Binding ToggleThemeCommand}" 
                                Content="{Binding IsDarkMode, Converter={x:Static vm:ThemeTextConverter.Instance}}"
                                DockPanel.Dock="Right" 
                                HorizontalAlignment="Right"
                                Padding="12,6"/>
                    </DockPanel>

                    <Separator Height="2"/>

                    <!-- Statistics -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Statistics" FontSize="18" FontWeight="Bold"/>
                        <TextBlock FontSize="16">
                            <Run Text="Sessions Today: " FontWeight="SemiBold"/>
                            <Run Text="{Binding SessionsCompletedToday}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding TargetSessions}"/>
                        </TextBlock>
                    </StackPanel>

                    <Separator Height="2"/>

                    <!-- Timer Settings -->
                    <StackPanel Spacing="15">
                        <TextBlock Text="Durations (minutes)" FontSize="18" FontWeight="Bold"/>
                        
                        <Grid ColumnDefinitions="*,120" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,5">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Work" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding WorkDuration}" Minimum="1" Maximum="60" Margin="0,4"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Short Break" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding ShortBreakDuration}" Minimum="1" Maximum="30" Margin="0,4"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Long Break" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding LongBreakDuration}" Minimum="1" Maximum="60" Margin="0,4"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Daily Target" VerticalAlignment="Center"/>
                            <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding TargetSessions}" Minimum="1" Maximum="50" Margin="0,4"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Panel>
</Window>
