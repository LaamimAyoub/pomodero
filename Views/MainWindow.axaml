<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:pomodero.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="650"
        Width="450" Height="650"
        x:Class="pomodero.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Pomodoro Timer"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <ScrollViewer>
        <StackPanel Margin="30" Spacing="25">
            <!-- Header & Theme Toggle -->
            <DockPanel>
                <TextBlock Text="Pomodoro" VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold"/>
                <Button Command="{Binding ToggleThemeCommand}" 
                        Content="{Binding IsDarkMode, Converter={x:Static vm:ThemeTextConverter.Instance}}"
                        DockPanel.Dock="Right" 
                        HorizontalAlignment="Right"
                        Padding="12,6"/>
            </DockPanel>

            <!-- Timer Display -->
            <StackPanel Spacing="15">
                <TextBlock Text="{Binding StatusText}" 
                           FontSize="24" 
                           HorizontalAlignment="Center"
                           FontWeight="Bold"
                           Foreground="{Binding StatusColor}"/>
                
                <TextBlock Text="{Binding TimeString}" 
                           FontSize="80" 
                           HorizontalAlignment="Center"
                           FontWeight="ExtraBold"
                           Foreground="{Binding StatusColor}"/>

                <!-- Session Dots (Daily Progress Grouped by 4) -->
                <ItemsControl HorizontalAlignment="Center">
                    <ItemsControl.ItemsSource>
                        <MultiBinding Converter="{x:Static vm:SessionGroupsConverter.Instance}">
                            <Binding Path="SessionsCompletedToday"/>
                            <Binding Path="TargetSessions"/>
                        </MultiBinding>
                    </ItemsControl.ItemsSource>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" MaxWidth="350" HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ItemsControl ItemsSource="{Binding}" Margin="10,5">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="6"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Ellipse Width="14" Height="14" Fill="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Controls -->
            <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Center">
                <Button Content="{Binding StartStopButtonText}" 
                        Command="{Binding StartStopCommand}"
                        Width="130" Height="50"
                        FontSize="20"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Classes="accent"/>
                
                <Button Content="Reset" 
                        Command="{Binding ResetCommand}"
                        Width="130" Height="50"
                        FontSize="20"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"/>
            </StackPanel>

            <Separator Height="2" Margin="0,10"/>

            <!-- Statistics -->
            <StackPanel Spacing="5" HorizontalAlignment="Center">
                <TextBlock HorizontalAlignment="Center" FontSize="16">
                    <Run Text="Sessions Today: " FontWeight="SemiBold"/>
                    <Run Text="{Binding SessionsCompletedToday}"/>
                    <Run Text=" / "/>
                    <Run Text="{Binding TargetSessions}"/>
                </TextBlock>
            </StackPanel>

            <!-- Settings -->
            <StackPanel Spacing="15">
                <TextBlock Text="Settings" FontSize="18" FontWeight="Bold"/>
                
                <Grid ColumnDefinitions="*,120" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,5">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Work Duration (min)" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding WorkDuration}" Minimum="1" Maximum="60" Margin="0,4"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Short Break (min)" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding ShortBreakDuration}" Minimum="1" Maximum="30" Margin="0,4"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Long Break (min)" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="2" Grid.Column="1" Value="{Binding LongBreakDuration}" Minimum="1" Maximum="60" Margin="0,4"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Daily Target Sessions" VerticalAlignment="Center"/>
                    <NumericUpDown Grid.Row="3" Grid.Column="1" Value="{Binding TargetSessions}" Minimum="1" Maximum="50" Margin="0,4"/>
                </Grid>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
